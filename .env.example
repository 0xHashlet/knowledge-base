APP_NAME="Enterprise RAG Knowledge Platform"
APP_VERSION="0.1.0"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password
