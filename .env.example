APP_NAME="Enterprise RAG Knowledge Platform"
APP_VERSION="0.1.0"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=enterprise_rag

REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-in-production-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

MILVUS_URI=http://milvus:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=enterprise_rag_chunks
VECTOR_DIMENSION=1024
EMBEDDING_ENDPOINT=http://localhost:8080/v1
EMBEDDING_MODEL=bge-large-zh-v1.5

OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=enterprise-rag-documents
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_REGION=us-east-1
